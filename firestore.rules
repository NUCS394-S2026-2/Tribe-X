rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write only their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Analyses are private to the user who created them.
    // Reads and updates are restricted to the owning uid.
    // Creates require the document's uid field to match the authenticated user.
    match /analyses/{analysisId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }
  }
}